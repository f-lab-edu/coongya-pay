<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flab.coongyapay.user.mapper.UserLoginHistoryMapper">

    <insert id="insert" parameterType="com.flab.coongyapay.user.mapper.dto.UserLoginHistoryDto"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_login_history (user_id, success, failure_reason, ip_address)
        VALUES (#{userId}, #{success}, #{failureReason}, #{ipAddress})
    </insert>

</mapper>