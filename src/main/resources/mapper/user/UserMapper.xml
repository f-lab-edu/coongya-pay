<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flab.coongyapay.user.mapper.UserMapper">

    <select id="existsByEmail" resultType="boolean">
        SELECT EXISTS(
            SELECT 1 FROM user
            WHERE email = #{email}
        )
    </select>

    <select id="findByEmailForUpdate" resultType="com.flab.coongyapay.user.mapper.dto.UserDto">
        SELECT id, email, name
        FROM user
        WHERE email = #{email}
        FOR UPDATE
    </select>

    <insert id="insert" parameterType="com.flab.coongyapay.user.mapper.dto.UserDto"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (email, name)
        VALUES (#{email}, #{name})
    </insert>

</mapper>