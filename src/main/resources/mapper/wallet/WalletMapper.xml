<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flab.coongyapay.wallet.mapper.WalletMapper">

    <insert id="insert" parameterType="com.flab.coongyapay.wallet.mapper.dto.WalletDto"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO wallet (user_id, balance, version)
        VALUES (#{userId}, #{balance}, #{version})
    </insert>

</mapper>